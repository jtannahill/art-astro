{
  "name": "art-astro",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "pull-data": "tsx scripts/pull-data.ts",
    "build": "npm run pull-data && astro build && npm run generate-og && npm run index-search",
    "build:no-pull": "astro build && npm run generate-og && npm run index-search",
    "generate-og": "tsx scripts/generate-og.ts",
    "index-search": "pagefind --site dist --output-subdir _pagefind",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@aws-sdk/client-dynamodb": "^3.1043.0",
    "@aws-sdk/util-dynamodb": "^3.996.2",
    "@fontsource/inter": "^5.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^6.2.2",
    "pagefind": "^1.5.2",
    "satori": "^0.26.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
