---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { getCollection } from "astro:content";

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  /** og:image override. Defaults to today's first artwork (1200px WebP). */
  ogImage?: string;
  /** og:type. Defaults to "website". */
  ogType?: string;
  /** Set false on pages (e.g. single artwork) that inject their own
   *  og:/twitter: tags via the head slot — prevents duplicate tags. */
  socialMeta?: boolean;
}

const {
  title,
  description,
  canonicalPath,
  ogImage,
  ogType = "website",
  socialMeta = true,
} = Astro.props;
const canonical = canonicalPath
  ? new URL(canonicalPath, Astro.site).toString()
  : new URL(Astro.url.pathname, Astro.site).toString();

// Default og:image: the strongest piece from the newest run in the
// build-time data snapshot. preview-1200.webp is the social-card-sized
// variant (~150-250 KB vs the 1.7 MB 2048 PNG).
const PROD = "https://art.jamestannahill.com";
let resolvedOgImage = ogImage;
if (socialMeta && !resolvedOgImage) {
  try {
    const weather = await getCollection("weather");
    const latest = weather
      .filter((w) => w.data.run_id && w.data.slug)
      .sort(
        (a, b) =>
          (b.data.run_id ?? "").localeCompare(a.data.run_id ?? "") ||
          (b.data.quality_score ?? 0) - (a.data.quality_score ?? 0)
      )[0];
    if (latest) {
      resolvedOgImage = `${PROD}/weather/${latest.data.run_id}/${latest.data.slug}/preview-1200.webp`;
    }
  } catch {
    // Data snapshot unavailable (fresh checkout before pull-data):
    // simply omit og:image rather than fail the build.
  }
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />
    {socialMeta && (
      <>
        <meta property="og:title" content={title} />
        {description && <meta property="og:description" content={description} />}
        <meta property="og:url" content={canonical} />
        <meta property="og:site_name" content="art.jt" />
        <meta property="og:type" content={ogType} />
        {resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}
        <meta name="twitter:card" content="summary_large_image" />
        {resolvedOgImage && <meta name="twitter:image" content={resolvedOgImage} />}
      </>
    )}
    <ClientRouter />
    <slot name="head" />
  </head>
  <body>
    <header class="hdr">
      <a href={import.meta.env.BASE_URL}>
        <span class="hdr-mark">art.jt</span>
      </a>
      <nav class="top-nav">
        <a href="/archive/">Archive</a>
        <a href="/artist/">Artists</a>
        <a href="/palettes/">Palettes</a>
        <a href="/map/">Map</a>
        <a href="/about/">About</a>
        <button class="nav-search-trigger" type="button" data-search-trigger aria-label="Search" title="Search (⌘K)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="7" />
            <path d="m20 20-3-3" />
          </svg>
          <span class="nav-search-text">Search</span>
          <kbd class="nav-search-kbd">⌘K</kbd>
        </button>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="ftr">
      <form class="ftr-subscribe" data-subscribe novalidate>
        <label for="ftr-email" class="ftr-sub-label">Daily digest</label>
        <input
          id="ftr-email"
          type="email"
          name="email"
          placeholder="you@example.com"
          required
          autocomplete="email"
          inputmode="email"
        />
        <button type="submit">Subscribe</button>
        <span class="ftr-sub-msg" data-subscribe-msg aria-live="polite"></span>
      </form>
      <p class="ftr-meta">
        Generative weather art by James Tannahill ·
        <a href="/about/">about</a> ·
        <a href="/rss.xml">rss</a> ·
        <a href="https://creativecommons.org/licenses/by-nc-nd/4.0/" target="_blank" rel="noopener">CC BY-NC-ND 4.0</a>
      </p>
    </footer>

    {/* Site-wide search modal. Pagefind UI is lazy-loaded on first
        open (~120 KB JS + ~14 KB CSS). Keyboard: ⌘K / ctrl+K opens,
        Esc closes. The modal also serves /search/ - clicking the
        nav button is shorthand for "open search anywhere on the site". */}
    <div class="search-modal" data-search-modal hidden>
      <div class="search-backdrop" data-search-close></div>
      <div class="search-panel" role="dialog" aria-label="Search">
        <button class="search-close" data-search-close aria-label="Close">×</button>
        <div id="nav-search"></div>
      </div>
    </div>

    <script is:inline>
      // Newsletter signup → art-api Lambda Function URL POST /subscribe.
      // Inline + delegated so the form keeps working across ClientRouter
      // page swaps without rebinding listeners per navigation.
      (function () {
        const SUBSCRIBE_URL =
          "https://kvorpfc3nbj6h7otsc2634duxm0xtqis.lambda-url.us-east-1.on.aws/subscribe";
        document.addEventListener("submit", async (e) => {
          const form = e.target.closest("[data-subscribe]");
          if (!form) return;
          e.preventDefault();
          const input = form.querySelector('input[type="email"]');
          const button = form.querySelector("button[type=submit]");
          const msg = form.querySelector("[data-subscribe-msg]");
          msg.className = "ftr-sub-msg";
          msg.textContent = "";
          const email = (input.value || "").trim();
          if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) {
            msg.textContent = "Please enter a valid email.";
            msg.classList.add("err");
            return;
          }
          button.disabled = true;
          button.textContent = "...";
          try {
            const r = await fetch(SUBSCRIBE_URL, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ email, source: "site_footer" }),
            });
            const data = await r.json().catch(() => ({}));
            if (r.ok && data.ok) {
              msg.textContent = "Subscribed. Check your inbox for the next digest.";
              msg.classList.add("ok");
              input.value = "";
            } else if (r.status === 400) {
              msg.textContent = data.error || "Please enter a valid email.";
              msg.classList.add("err");
            } else {
              // Duplicate subscriptions throw on the server (DynamoDB
              // ConditionExpression). Treat as success from the user's
              // perspective so they're not nagged.
              msg.textContent = "You're on the list.";
              msg.classList.add("ok");
              input.value = "";
            }
          } catch {
            msg.textContent = "Connection error. Try again.";
            msg.classList.add("err");
          } finally {
            button.disabled = false;
            button.textContent = "Subscribe";
          }
        });
      })();

      (function () {
        const modal = document.querySelector("[data-search-modal]");
        if (!modal) return;
        let cssLoaded = false;
        let scriptLoaded = false;
        let mounted = false;

        function ensureAssets() {
          if (!cssLoaded) {
            const link = document.createElement("link");
            link.rel = "stylesheet";
            link.href = "/_pagefind/pagefind-ui.css";
            document.head.appendChild(link);
            cssLoaded = true;
          }
          if (!scriptLoaded) {
            return new Promise((resolve, reject) => {
              const s = document.createElement("script");
              s.src = "/_pagefind/pagefind-ui.js";
              s.onload = () => { scriptLoaded = true; resolve(); };
              s.onerror = reject;
              document.head.appendChild(s);
            });
          }
          return Promise.resolve();
        }

        async function mount() {
          if (mounted) return;
          await ensureAssets();
          // Wait for the global to actually exist (script runs async)
          let tries = 0;
          await new Promise((resolve) => {
            (function tick() {
              if (typeof PagefindUI !== "undefined") return resolve();
              if (tries++ < 60) return setTimeout(tick, 50);
              resolve();
            })();
          });
          if (typeof PagefindUI === "undefined") return;
          new PagefindUI({
            element: "#nav-search",
            showImages: false,
            resetStyles: false,
            showSubResults: true,
            autofocus: true,
            translations: { placeholder: "Search rationale, artist, location..." },
          });
          mounted = true;
        }

        async function open() {
          modal.hidden = false;
          await mount();
          // Focus the input once mounted
          const input = modal.querySelector(".pagefind-ui__search-input");
          if (input) input.focus();
        }
        function close() {
          modal.hidden = true;
        }

        document.addEventListener("click", (e) => {
          const trigger = e.target.closest("[data-search-trigger]");
          if (trigger) { e.preventDefault(); open(); return; }
          if (e.target.closest("[data-search-close]")) { close(); return; }
        });
        document.addEventListener("keydown", (e) => {
          const isCmdK = (e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k";
          if (isCmdK) { e.preventDefault(); modal.hidden ? open() : close(); }
          else if (e.key === "Escape" && !modal.hidden) close();
          else if (e.key === "/" && modal.hidden) {
            // "/" opens search - but only when the user isn't typing in a field
            const ae = document.activeElement;
            if (ae && (ae.tagName === "INPUT" || ae.tagName === "TEXTAREA")) return;
            e.preventDefault(); open();
          }
        });
      })();
    </script>

    <style>
      .hdr {
        position: sticky;
        top: 0;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.75rem 1.5rem;
        background: rgba(10, 10, 15, 0.85);
        backdrop-filter: saturate(180%) blur(10px);
        -webkit-backdrop-filter: saturate(180%) blur(10px);
        border-bottom: 1px solid var(--color-border);
      }
      .hdr a { color: var(--color-fg); font-family: var(--font-mono); font-size: 0.9rem; }
      .top-nav { display: flex; gap: 1rem; flex-wrap: wrap; }
      .top-nav a {
        color: var(--color-muted);
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        text-decoration: none;
      }
      .top-nav a:hover { color: var(--color-link); }

      .nav-search-trigger {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.3rem 0.65rem 0.3rem 0.55rem;
        background: #141428;
        border: 1px solid #2a2a3e;
        border-radius: 999px;
        color: var(--color-muted);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        cursor: pointer;
        transition: border-color 0.15s, color 0.15s, background 0.15s;
        font-family: inherit;
      }
      .nav-search-trigger:hover {
        border-color: var(--color-accent);
        color: var(--color-accent);
        background: #1a1a2e;
      }
      .nav-search-trigger svg { flex-shrink: 0; }
      .nav-search-kbd {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        padding: 1px 5px;
        background: #0a0a0f;
        border: 1px solid #2a2a3e;
        border-radius: 4px;
        color: var(--color-muted);
        letter-spacing: 0;
      }
      @media (max-width: 520px) {
        .hdr { flex-wrap: wrap; gap: 0.5rem 0.75rem; padding: 0.6rem 1rem; }
        .top-nav { gap: 0.6rem; }
        .top-nav a { font-size: 0.7rem; }
        .nav-search-text, .nav-search-kbd { display: none; }
        .nav-search-trigger { padding: 0.3rem; }
      }

      .search-modal {
        position: fixed;
        inset: 0;
        z-index: 200;
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding: 6vh 1rem 0;
      }
      .search-modal[hidden] { display: none; }
      .search-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(5, 5, 12, 0.8);
        backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px);
      }
      .search-panel {
        position: relative;
        width: min(680px, 100%);
        max-height: 80vh;
        overflow: auto;
        background: #0d0d18;
        border: 1px solid #2a2a3e;
        border-radius: 14px;
        padding: 1.25rem 1.25rem 1rem;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6);
      }
      .search-close {
        position: absolute;
        top: 0.5rem;
        right: 0.65rem;
        background: none;
        border: none;
        color: var(--color-muted);
        font-size: 1.5rem;
        cursor: pointer;
        line-height: 1;
        padding: 0.2rem 0.5rem;
      }
      .search-close:hover { color: #fff; }

      /* Pagefind UI theming inside the modal - match dark monochrome */
      .search-panel :global(.pagefind-ui) {
        --pagefind-ui-primary: var(--color-accent);
        --pagefind-ui-text: #ddd;
        --pagefind-ui-background: transparent;
        --pagefind-ui-border: #2a2a3e;
        --pagefind-ui-tag: #1a1a2e;
        --pagefind-ui-border-radius: 8px;
        --pagefind-ui-image-border-radius: 4px;
        --pagefind-ui-image-box-ratio: 1 / 1;
        --pagefind-ui-font: var(--font-sans);
      }
      .search-panel :global(.pagefind-ui__search-input) {
        background: #0a0a14 !important;
        color: var(--color-fg) !important;
      }
      .search-panel :global(.pagefind-ui__result-link) { color: var(--color-link) !important; }
      main {
        max-width: 720px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
      }
      .ftr {
        max-width: 720px;
        margin: 6rem auto 2rem;
        padding: 1.5rem;
        border-top: 1px solid var(--color-border);
        font-size: 0.8rem;
        color: var(--color-muted);
      }
      .ftr-subscribe {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        align-items: center;
        margin: 0 0 1rem;
      }
      .ftr-sub-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--color-muted);
        margin-right: 0.25rem;
      }
      .ftr-subscribe input[type="email"] {
        flex: 1 1 220px;
        min-width: 0;
        background: #0e0e1a;
        border: 1px solid #2a2a3e;
        color: var(--color-fg);
        font: inherit;
        padding: 0.45rem 0.7rem;
        border-radius: 6px;
        outline: none;
      }
      .ftr-subscribe input[type="email"]:focus {
        border-color: var(--color-accent);
      }
      .ftr-subscribe button {
        padding: 0.45rem 0.95rem;
        background: linear-gradient(135deg, #2a1a4e, #1a1a3e);
        border: 1px solid #c4b5fd44;
        border-radius: 6px;
        color: var(--color-accent);
        font: inherit;
        font-size: 0.78rem;
        cursor: pointer;
        transition: border-color 0.15s, background 0.15s;
      }
      .ftr-subscribe button:hover {
        border-color: #c4b5fd88;
        background: linear-gradient(135deg, #3a2a6e, #2a2a5e);
      }
      .ftr-subscribe button:disabled { opacity: 0.5; cursor: default; }
      .ftr-sub-msg {
        font-size: 0.75rem;
        color: var(--color-muted);
        flex-basis: 100%;
        min-height: 1.1em;
      }
      .ftr-sub-msg.ok { color: #4ade80; }
      .ftr-sub-msg.err { color: #ff8b8b; }
      .ftr-meta { margin: 0; }
    </style>
  </body>
</html>
