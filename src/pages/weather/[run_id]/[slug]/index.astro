---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Base from "../../../../layouts/Base.astro";
import { ARTISTS_BY_KEY } from "../../../../data/artists.ts";

export const getStaticPaths: GetStaticPaths = async () => {
  const all = await getCollection("weather");
  return all
    .filter((w) => w.data.run_id && w.data.slug)
    .map((w) => ({
      params: { run_id: w.data.run_id, slug: w.data.slug },
      props: { piece: w.data },
    }));
};

const { piece } = Astro.props as { piece: import("astro:content").CollectionEntry<"weather">["data"] };

const PROD = "https://art.jamestannahill.com";
const WATERMARK_URL = "https://6sdaen4674towfh6p3lwnb4dta0cggvr.lambda-url.us-east-1.on.aws";
const PRINT_SHOP_URL = "https://s4qic3km3mmmaz377eiw5ggsrm0seuvs.lambda-url.us-east-1.on.aws";

const assetBase = `${PROD}/weather/${piece.run_id}/${piece.slug}`;
const previewUrl = `${assetBase}/preview-2048.png`;
// Social-card image: 1200px WebP (~150-250 KB) instead of the 1.7 MB
// 2048 PNG. Scrapers want ~1200px and time out on multi-MB images.
const ogImageUrl = `${assetBase}/preview-1200.webp`;
const svgUrl = `${assetBase}/artwork.svg`;

const artist = ARTISTS_BY_KEY[piece.artist];
const artistName = artist?.display ?? piece.artist.replace(/_/g, " ");

function pretty(slug: string) {
  return slug
    .split("-")
    .map((s) => s.charAt(0).toUpperCase() + s.slice(1))
    .join(" ");
}

function coords(lat?: number, lng?: number) {
  if (lat == null || lng == null) return "";
  const ns = lat >= 0 ? "N" : "S";
  const ew = lng >= 0 ? "E" : "W";
  return `${Math.abs(lat).toFixed(0)}°${ns}, ${Math.abs(lng).toFixed(0)}°${ew}`;
}

const title = pretty(piece.slug);
const description =
  piece.rationale && piece.rationale.length > 0
    ? piece.rationale.slice(0, 200) + (piece.rationale.length > 200 ? "..." : "")
    : `Generative weather art at ${title} on ${piece.date}.`;

const [w, h] = (piece.canvas_format || "2048x2048").split("x");

const visualArtwork = {
  "@context": "https://schema.org",
  "@type": "VisualArtwork",
  name: `${title} - ${piece.date}`,
  description: piece.rationale,
  url: `${PROD}/weather/${piece.run_id}/${piece.slug}/`,
  image: previewUrl,
  dateCreated: piece.created_at || piece.date,
  artMedium: `Digital - generative art from atmospheric data${piece.renderer === "flux-1.1-pro" ? " (Flux 1.1 Pro)" : " (SVG)"}`,
  artform: "Generative Art",
  artworkSurface: "Digital",
  width: { "@type": "Distance", name: `${w}px` },
  height: { "@type": "Distance", name: `${h}px` },
  creator: { "@type": "Person", name: "James Tannahill", url: "https://jamestannahill.com" },
  license: "https://creativecommons.org/licenses/by-nc-nd/4.0/",
  copyrightHolder: { "@type": "Person", name: "James Tannahill" },
  copyrightYear: "2026",
  locationCreated: {
    "@type": "Place",
    geo: {
      "@type": "GeoCoordinates",
      latitude: piece.lat ?? "",
      longitude: piece.lng ?? "",
    },
  },
  about: [
    { "@type": "Thing", name: "Weather Art" },
    { "@type": "Thing", name: artistName },
    { "@type": "Thing", name: "Abstract Expressionism" },
    { "@type": "Thing", name: "Generative Art" },
  ],
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${PROD}/` },
    { "@type": "ListItem", position: 2, name: "Archive", item: `${PROD}/weather/` },
    {
      "@type": "ListItem",
      position: 3,
      name: piece.run_id,
      item: `${PROD}/weather/${piece.run_id}/`,
    },
    { "@type": "ListItem", position: 4, name: title },
  ],
};

const TIPS = {
  pressure:
    "Sea-level atmospheric pressure. Deep lows create density, weight, and compressed energy. High pressure opens up the canvas.",
  gradient:
    "Rate of pressure change across the region. Steep gradients drive turbulent compositions; flat gradients yield calm work.",
  wind:
    "Wind speed drives kinetic energy. Strong winds produce sweeping directional strokes; calm air yields stillness.",
  temp:
    "Surface temperature shapes the color palette. Heat pushes toward saturated hues; cold toward stark contrasts.",
  anomaly:
    "Deviation from the average temperature at this latitude. Large anomalies intensify the visual drama.",
  humidity:
    "Atmospheric moisture content. High humidity softens edges and blends colors; dry air sharpens boundaries.",
  precipitation:
    "Active rainfall or snowfall. Adds textural density - dripping, pooling, layered opacity effects.",
  score:
    "Composite score: pressure anomaly (30%) + wind (25%) + temp anomaly (20%) + precipitation (15%) + humidity (10%). Higher = more dramatic conditions.",
};
---

{/* socialMeta={false}: this page emits its own og:/twitter: tags below —
    the Base defaults would duplicate them. */}
<Base title={`${title} - ${piece.date} - art.jt`} description={description} canonicalPath={`/weather/${piece.run_id}/${piece.slug}/`} socialMeta={false}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(visualArtwork)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={`${title} - Weather Art - ${piece.date}`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`${PROD}/weather/${piece.run_id}/${piece.slug}/`} />
    <meta property="og:site_name" content="art.jt" />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
  </Fragment>

  <nav class="crumbs">
    <a href="/">Home</a>
    <span>/</span>
    <a href="/archive/">Archive</a>
    <span>/</span>
    <span class="muted">{piece.run_id}</span>
    <span>/</span>
    <span>{title}</span>
  </nav>

  <div data-pagefind-body>
  <h1 data-pagefind-meta="title">{title}</h1>
  <p class="lede muted">
    {coords(piece.lat, piece.lng)} ·
    <a href={`/artist/${piece.artist}/`}>{artistName}</a> ·
    {piece.date}
  </p>

  {/* Hidden Pagefind metadata + filters. The page body itself is indexed
       via data-pagefind-body on <main>. These spans give the search index
       structured fields it can return + facet on. */}
  <span data-pagefind-meta={`artist:${artistName}`} hidden>{artistName}</span>
  <span data-pagefind-meta={`date:${piece.date}`} hidden>{piece.date}</span>
  <span data-pagefind-filter={`artist:${artistName}`} hidden>{artistName}</span>
  <span data-pagefind-filter={`year:${piece.date.slice(0, 4)}`} hidden>{piece.date.slice(0, 4)}</span>

  <figure class="hero">
    {/* WebP srcset keeps the LCP hero under ~200 KB; the 2048 PNG
        (~1.7 MB) remains the fallback for any piece missing variants. */}
    <picture>
      <source
        type="image/webp"
        srcset={`${assetBase}/preview-960.webp 960w, ${assetBase}/preview-1920.webp 1920w`}
        sizes="(max-width: 768px) 100vw, 672px"
      />
      <img
        src={previewUrl}
        alt={`${piece.slug} weather artwork`}
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width={w}
        height={h}
        style={`view-transition-name: art-${piece.run_id.replace(/-/g, "")}-${piece.slug.replace(/-/g, "")};`}
      />
    </picture>
  </figure>

  <div class="actions">
    <button class="btn primary" data-print-open>
      <span>Buy print</span>
      <span class="sub">Limited Edition · Ships Worldwide</span>
    </button>
    {/* Watermark Lambda 302-redirects to S3 cross-origin, which makes
         browsers ignore the `download` attribute. target="_blank" keeps
         the visitor on this page while the download happens in a new tab. */}
    {piece.has_8k && (
      <a class="btn" target="_blank" rel="noopener"
        href={`${WATERMARK_URL}?r=${piece.run_id}&s=${piece.slug}&z=8k`}
        download={`${piece.slug}-${piece.artist}-${piece.run_id}-8k.png`}>Download PNG (8K)</a>
    )}
    <a class="btn" target="_blank" rel="noopener"
      href={`${WATERMARK_URL}?r=${piece.run_id}&s=${piece.slug}&z=4k`}
      download={`${piece.slug}-${piece.artist}-${piece.run_id}-4k.png`}>Download PNG (4K)</a>
    {piece.has_svg && (
      <a class="btn ghost" target="_blank" rel="noopener"
        href={svgUrl}
        download={`${piece.slug}-${piece.artist}-${piece.run_id}-vector.svg`}>Download SVG</a>
    )}
  </div>

  {piece.rationale && (
    <section class="rationale">
      <h2>Creative Rationale</h2>
      <p>{piece.rationale}</p>
    </section>
  )}

  <section class="meta">
    <h2>Atmospheric Data</h2>
    <dl>
      <dt>Date</dt>
      <dd>{piece.date}</dd>
      <dt>Location</dt>
      <dd>{coords(piece.lat, piece.lng)} ({title})</dd>
      {piece.pressure != null && (
        <>
          <dt><span title={TIPS.pressure}>Pressure</span></dt>
          <dd>
            {piece.pressure} hPa
            {piece.pressure_gradient != null && (
              <span class="muted"> (<span title={TIPS.gradient}>gradient: {piece.pressure_gradient}</span>)</span>
            )}
          </dd>
        </>
      )}
      {piece.wind_speed != null && (
        <>
          <dt><span title={TIPS.wind}>Wind</span></dt>
          <dd>{piece.wind_speed} m/s{piece.wind_direction != null && <> from {piece.wind_direction}°</>}</dd>
        </>
      )}
      {piece.temp != null && (
        <>
          <dt><span title={TIPS.temp}>Temperature</span></dt>
          <dd>
            {piece.temp}°C
            {piece.temp_anomaly != null && (
              <span class="muted"> (<span title={TIPS.anomaly}>anomaly: {piece.temp_anomaly}°C</span>)</span>
            )}
          </dd>
        </>
      )}
      {piece.humidity != null && (
        <>
          <dt><span title={TIPS.humidity}>Humidity</span></dt>
          <dd>{piece.humidity}%</dd>
        </>
      )}
      {piece.precipitation != null && piece.precipitation > 0 && (
        <>
          <dt><span title={TIPS.precipitation}>Precipitation</span></dt>
          <dd>{piece.precipitation} mm</dd>
        </>
      )}
      {piece.score != null && (
        <>
          <dt><span title={TIPS.score}>Visual Interest Score</span></dt>
          <dd>{piece.score}</dd>
        </>
      )}
    </dl>
  </section>

  <section class="meta">
    <h2>Technical Details</h2>
    <dl>
      <dt>Model</dt>
      <dd>{piece.renderer === "flux-1.1-pro" ? "Flux 1.1 Pro (Black Forest Labs)" : "Claude Sonnet 4 via Amazon Bedrock"}</dd>
      <dt>Artist Inspiration</dt>
      <dd><a href={`/artist/${piece.artist}/`}>{artistName}</a></dd>
      <dt>Weather Source</dt>
      <dd>Open-Meteo API (GFS model)</dd>
      <dt>Format</dt>
      <dd>
        {piece.renderer === "flux-1.1-pro" ? (
          piece.has_8k ? "PNG 8K (Flux 1.1 Pro → Real-ESRGAN 4× → Clarity 2×)" : "PNG 4K (Flux 1.1 Pro + Real-ESRGAN 4×)"
        ) : `SVG (${piece.canvas_format} viewBox) + PNG`}
        {piece.has_svg && piece.renderer === "flux-1.1-pro" && " + SVG vector interpretation"}
      </dd>
      <dt>Generated</dt>
      <dd>{piece.created_at || piece.run_id}</dd>
      <dt>Run ID</dt>
      <dd class="mono">{piece.run_id}</dd>
    </dl>
  </section>

  <p class="license">
    <strong>License:</strong> CC BY-NC-ND 4.0. Attribution: James Tannahill / art.jamestannahill.com.
    No commercial use or derivatives without permission.
  </p>
  </div>

  {/* Print drawer + Stripe checkout. Fetches available sizes from the
       print-shop Lambda and POSTs the selected size for a Stripe Checkout
       redirect. Same flow as the legacy Jinja2 page. */}
  <div class="drawer-overlay" data-drawer-overlay></div>
  <aside class="drawer" data-drawer aria-hidden="true">
    <button class="drawer-close" data-drawer-close aria-label="Close print options">×</button>
    <img class="drawer-thumb" src={`${assetBase}/preview-480.webp`} alt={piece.slug} loading="lazy" decoding="async" width={w} height={h} />
    <h3 class="drawer-title">{title}</h3>
    <p class="drawer-sub">{artistName} · {piece.date}</p>
    <div class="size-options" data-size-options>
      <p class="muted">Loading sizes...</p>
    </div>
    <button class="checkout-btn" data-checkout disabled>Select a size</button>
    <div class="trust-signals">
      <span>Ships worldwide via theprintspace</span>
      <span>Hahnemühle German Etching 310gsm</span>
      <span>Certificate of Authenticity included</span>
    </div>
  </aside>

  <script
    is:inline
    define:vars={{ PRINT_SHOP_URL, RUN_ID: piece.run_id, SLUG: piece.slug }}
  >
    (function () {
      const overlay = document.querySelector("[data-drawer-overlay]");
      const drawer = document.querySelector("[data-drawer]");
      const sizeBox = document.querySelector("[data-size-options]");
      const checkoutBtn = document.querySelector("[data-checkout]");
      let selectedSize = null;
      let editionsLoaded = false;

      function open() {
        overlay.classList.add("open");
        drawer.classList.add("open");
        drawer.setAttribute("aria-hidden", "false");
        if (!editionsLoaded) loadEditions();
      }
      function close() {
        overlay.classList.remove("open");
        drawer.classList.remove("open");
        drawer.setAttribute("aria-hidden", "true");
      }

      document.querySelectorAll("[data-print-open]").forEach((b) => b.addEventListener("click", open));
      document.querySelector("[data-drawer-close]").addEventListener("click", close);
      overlay.addEventListener("click", close);
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && drawer.classList.contains("open")) close();
      });

      function loadEditions() {
        sizeBox.innerHTML = '<p class="size-loading">Loading sizes...</p>';
        // 12s timeout — print-shop Lambda's cold start can stretch
        const controller = new AbortController();
        const timer = setTimeout(() => controller.abort(), 12000);
        fetch(
          PRINT_SHOP_URL + "?action=editions&run_id=" + RUN_ID + "&slug=" + SLUG,
          { signal: controller.signal }
        )
          .then((r) => {
            if (!r.ok) throw new Error("status " + r.status);
            return r.json();
          })
          .then((data) => {
            clearTimeout(timer);
            editionsLoaded = true;
            sizeBox.innerHTML = "";
            const order = ["S", "M", "L", "XL", "XXL"];
            order.forEach((key) => {
              const s = (data.sizes || {})[key];
              if (!s) return;
              const soldOut = s.sold >= s.limit;
              const div = document.createElement("div");
              div.className = "size-option" + (soldOut ? " sold-out" : "");
              div.dataset.size = key;
              div.dataset.price = s.price_cents;
              div.addEventListener("click", () => selectSize(key, s.price_cents));
              div.innerHTML =
                '<div>' +
                  '<div class="size-label">' + key + ' · ' + s.dims + '"</div>' +
                  '<div class="size-edition">' + s.sold + ' of ' + s.limit + ' sold</div>' +
                '</div>' +
                '<div>' +
                  (soldOut
                    ? '<span class="sold-out-badge">Sold Out</span>'
                    : '<span class="size-price">$' + (s.price_cents / 100).toFixed(0) + '</span>') +
                '</div>';
              sizeBox.appendChild(div);
            });
          })
          .catch((err) => {
            clearTimeout(timer);
            const msg =
              err && err.name === "AbortError"
                ? "Sizes are taking longer than usual."
                : "Couldn't load sizes.";
            sizeBox.innerHTML =
              '<p class="size-error">' + msg + '</p>' +
              '<button type="button" class="size-retry" data-size-retry>Retry</button>';
            const retry = sizeBox.querySelector("[data-size-retry]");
            if (retry) retry.addEventListener("click", () => loadEditions());
          });
      }

      function selectSize(key, priceCents) {
        selectedSize = key;
        document.querySelectorAll(".size-option").forEach((el) =>
          el.classList.toggle("selected", el.dataset.size === key)
        );
        checkoutBtn.disabled = false;
        checkoutBtn.textContent = "Checkout - $" + (priceCents / 100).toFixed(0);
      }

      checkoutBtn.addEventListener("click", () => {
        if (!selectedSize) return;
        checkoutBtn.disabled = true;
        checkoutBtn.textContent = "Redirecting...";
        fetch(PRINT_SHOP_URL + "?action=checkout", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ run_id: RUN_ID, slug: SLUG, size_key: selectedSize }),
        })
          .then((r) => r.json())
          .then((data) => {
            if (data.url) {
              window.location.href = data.url;
            } else {
              checkoutBtn.textContent = data.error === "sold_out" ? "Sold Out" : "Error - try again";
              setTimeout(() => {
                checkoutBtn.disabled = false;
                checkoutBtn.textContent = "Checkout";
              }, 3000);
            }
          })
          .catch(() => {
            checkoutBtn.disabled = false;
            checkoutBtn.textContent = "Error - try again";
          });
      });
    })();
  </script>
</Base>

<style>
  .crumbs {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin-bottom: 1rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .crumbs a { color: var(--color-link); }
  h1 {
    font-size: 2rem;
    margin: 0 0 0.25rem;
    letter-spacing: -0.02em;
    text-transform: capitalize;
  }
  .lede { font-size: 0.95rem; margin: 0 0 1.5rem; }
  .lede a { color: var(--color-accent); }

  figure.hero {
    margin: 0 0 1.5rem;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #1f1f1f;
    background: #0a0a0a;
  }
  figure.hero img {
    width: 100%;
    height: auto;
    display: block;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0 0 2rem;
  }
  .btn {
    display: inline-block;
    padding: 0.5rem 1rem;
    border: 1px solid #2a2a2a;
    border-radius: 6px;
    color: #ddd;
    text-decoration: none;
    font-size: 0.85rem;
    background: #111;
    transition: border-color 0.15s, color 0.15s;
  }
  .btn:hover { border-color: #444; color: #fff; text-decoration: none; }
  .btn.primary {
    background: linear-gradient(135deg, #2a2218, #1a1814);
    border-color: #c9a66b55;
    color: var(--color-accent);
    font-weight: 600;
    cursor: pointer;
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.1rem;
    line-height: 1.2;
  }
  .btn.primary .sub { font-size: 0.65rem; opacity: 0.7; font-weight: 400; }
  .btn.ghost { opacity: 0.6; }

  /* Print drawer.
     The size-option / size-label / size-edition / size-price / selected /
     sold-out / sold-out-badge selectors below use :global() because the
     rows are inserted by JS after render and don't carry Astro's scoped
     data-astro-cid attribute. Without :global the styles never match. */
  .drawer-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    z-index: 100;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }
  .drawer-overlay.open { opacity: 1; pointer-events: auto; }
  .drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(420px, 90vw);
    background: #0d0d0d;
    border-left: 1px solid #2a2a2a;
    z-index: 101;
    transform: translateX(100%);
    transition: transform 0.3s;
    overflow-y: auto;
    padding: 1.5rem;
  }
  .drawer.open { transform: translateX(0); }
  .drawer-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    color: var(--color-muted);
    font-size: 1.5rem;
    cursor: pointer;
  }
  .drawer-close:hover { color: #fff; }
  .drawer-thumb {
    width: 100%;
    max-width: 200px;
    /* The height attribute is a presentational hint; without an author
       height it applies literally and stretches the thumb. */
    height: auto;
    display: block;
    margin: 0 auto 1rem;
    border-radius: 4px;
  }
  .drawer-title { color: #fff; font-size: 1.1rem; margin: 0 0 0.3rem; }
  .drawer-sub { color: var(--color-muted); font-size: 0.85rem; margin: 0 0 1.5rem; text-transform: capitalize; }
  .size-options {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  :global(.size-error) { color: #ff8b8b; font-size: 0.9rem; padding: 0.5rem 0 0.25rem; margin: 0; }
  :global(.size-loading) { color: var(--color-muted); font-size: 0.9rem; padding: 0.5rem 0; margin: 0; }
  :global(.size-retry) {
    background: #1a1a2e;
    border: 1px solid #2a2a3e;
    color: var(--color-accent);
    border-radius: 6px;
    padding: 0.3rem 0.8rem;
    font: inherit;
    font-size: 0.8rem;
    cursor: pointer;
  }
  :global(.size-retry:hover) { border-color: var(--color-accent); }
  :global(.size-option) {
    display: flex !important;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    background: #141414;
    border: 1px solid #2a2a2a;
    border-radius: 6px;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  :global(.size-option:hover) { border-color: #444; }
  :global(.size-option.selected) {
    border-color: var(--color-accent);
    background: #1a1814;
  }
  :global(.size-option.sold-out) { opacity: 0.4; pointer-events: none; }
  :global(.size-label) { color: #fff; font-size: 0.95rem; }
  :global(.size-edition) { color: #666; font-size: 0.75rem; margin-top: 0.15rem; }
  :global(.size-price) { color: var(--color-accent); font-size: 1rem; font-weight: 600; }
  :global(.sold-out-badge) {
    background: #331111;
    color: #ff6b6b;
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
  }
  .checkout-btn {
    display: block;
    width: 100%;
    padding: 0.85rem;
    background: linear-gradient(135deg, #1a1814, #2a2218);
    border: 1px solid #444;
    border-radius: 6px;
    color: var(--color-accent);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
