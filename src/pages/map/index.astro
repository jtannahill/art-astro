---
/**
 * Mapbox dark globe with weather artwork + palette markers.
 * Marker data baked into the page at build time; Mapbox renders client-side.
 *
 * The pk.* token below is a public client token — same one production uses
 * (it's exposed in every page's HTML there too).
 */
import { getCollection } from "astro:content";
import { PUBLIC_MAPBOX_TOKEN } from "astro:env/client";
import Base from "../../layouts/Base.astro";

const PROD = "https://art.jamestannahill.com";
const MAPBOX_TOKEN = PUBLIC_MAPBOX_TOKEN;

const allWeather = await getCollection("weather");
const allPalettes = await getCollection("palettes");

interface MarkerW {
  lat: number;
  lng: number;
  title: string;
  artist: string;
  url: string;
  img: string;
}
interface MarkerP {
  lat: number;
  lng: number;
  title: string;
  url: string;
  img: string;
}

const weatherMarkers: MarkerW[] = allWeather
  .filter((w) => w.data.lat != null && w.data.lng != null && w.data.run_id && w.data.slug)
  .map((w) => ({
    lat: w.data.lat!,
    lng: w.data.lng!,
    title: w.data.slug.replace(/-/g, " "),
    artist: w.data.artist,
    url: `/weather/${w.data.run_id}/${w.data.slug}/`,
    img: `${PROD}/weather/${w.data.run_id}/${w.data.slug}/preview-2048.png`,
  }));

// One palette pin per location (latest sample)
const latestPerLocation = new Map<string, (typeof allPalettes)[number]>();
for (const p of allPalettes) {
  const cur = latestPerLocation.get(p.data.location_slug);
  if (!cur || (p.data.date ?? "").localeCompare(cur.data.date ?? "") > 0) {
    latestPerLocation.set(p.data.location_slug, p);
  }
}
const paletteMarkers: MarkerP[] = [...latestPerLocation.values()]
  .filter((p) => p.data.lat != null && p.data.lng != null)
  .map((p) => ({
    lat: p.data.lat!,
    lng: p.data.lng!,
    title: p.data.location_slug.replace(/-/g, " "),
    url: `/palettes/${p.data.location_slug}/`,
    img: `${PROD}/palettes/${p.data.date}/${p.data.location_slug}/source-thumb.jpg`,
  }));
---

<Base
  title="World Map- art.jt"
  description="Every artwork and palette plotted on a dark globe."
>
  <h1>World Map</h1>
  <p class="lede muted">
    Every artwork and palette location, plotted on a Mapbox dark globe.
    {weatherMarkers.length} weather pins · {paletteMarkers.length} palette pins.
  </p>

  <div id="map" class="map"></div>

  <link rel="stylesheet" href="https://api.mapbox.com/mapbox-gl-js/v3.7.0/mapbox-gl.css" />
  <script
    src="https://api.mapbox.com/mapbox-gl-js/v3.7.0/mapbox-gl.js"
    is:inline
  ></script>

  <script
    is:inline
    define:vars={{ MAPBOX_TOKEN, weatherMarkers, paletteMarkers }}
  >
    function init() {
      if (typeof mapboxgl === "undefined") {
        setTimeout(init, 60);
        return;
      }
      mapboxgl.accessToken = MAPBOX_TOKEN;
      const map = new mapboxgl.Map({
        container: "map",
        style: "mapbox://styles/mapbox/dark-v11",
        projection: "globe",
        zoom: 1.4,
        center: [-30, 30],
      });
      map.on("style.load", () => {
        map.setFog({
          color: "rgb(20, 20, 30)",
          "high-color": "rgb(40, 30, 60)",
          "horizon-blend": 0.05,
          "space-color": "rgb(8, 8, 14)",
          "star-intensity": 0.6,
        });
      });

      function popupHtml(p) {
        const isPalette = p.kind === "p";
        return (
          '<div style="font-family:-apple-system,sans-serif;color:#ccc;background:#0a0a0a;border-radius:6px;overflow:hidden;width:200px;">' +
          '<img src="' + p.img + '" loading="lazy" style="width:100%;display:block;background:#000;aspect-ratio:1;object-fit:cover;">' +
          '<div style="padding:0.5rem 0.75rem;">' +
          '<div style="font-size:0.85rem;color:#fff;text-transform:capitalize;margin-bottom:0.2rem;">' + p.title + '</div>' +
          (isPalette
            ? '<div style="font-size:0.7rem;color:#888;">satellite palette</div>'
            : '<div style="font-size:0.7rem;color:#c4b5fd;">' + (p.artist || "").replace(/_/g, " ") + '</div>') +
          '<a href="' + p.url + '" style="display:inline-block;margin-top:0.4rem;font-size:0.75rem;color:#8ab4f8;">view →</a>' +
          '</div></div>'
        );
      }

      function toFeatures(arr, kind) {
        return arr.map((m) => ({
          type: "Feature",
          geometry: { type: "Point", coordinates: [m.lng, m.lat] },
          properties: { kind, ...m },
        }));
      }

      map.on("load", () => {
        const features = [
          ...toFeatures(weatherMarkers, "w"),
          ...toFeatures(paletteMarkers, "p"),
        ];
        map.addSource("pieces", {
          type: "geojson",
          data: { type: "FeatureCollection", features },
          cluster: true,
          clusterMaxZoom: 6,
          clusterRadius: 40,
        });

        map.addLayer({
          id: "clusters",
          type: "circle",
          source: "pieces",
          filter: ["has", "point_count"],
          paint: {
            "circle-color": [
              "step", ["get", "point_count"],
              "#4a3a8e", 10,
              "#6a4ace", 50,
              "#9c83ff",
            ],
            "circle-radius": [
              "step", ["get", "point_count"],
              14, 10, 20, 50, 28,
            ],
            "circle-stroke-color": "rgba(255,255,255,0.15)",
            "circle-stroke-width": 1,
            "circle-opacity": 0.85,
          },
        });
        map.addLayer({
          id: "cluster-count",
          type: "symbol",
          source: "pieces",
          filter: ["has", "point_count"],
          layout: {
            "text-field": ["get", "point_count_abbreviated"],
            "text-font": ["DIN Offc Pro Medium", "Arial Unicode MS Bold"],
            "text-size": 12,
          },
          paint: { "text-color": "#fff" },
        });
        map.addLayer({
          id: "pins",
          type: "circle",
          source: "pieces",
          filter: ["!", ["has", "point_count"]],
          paint: {
            "circle-color": [
              "match", ["get", "kind"],
              "p", "#4ade80",
              "#c4b5fd",
            ],
            "circle-radius": 6,
            "circle-stroke-color": "rgba(255,255,255,0.25)",
            "circle-stroke-width": 1,
          },
        });

        map.on("click", "clusters", (e) => {
          const f = map.queryRenderedFeatures(e.point, { layers: ["clusters"] })[0];
          const clusterId = f.properties.cluster_id;
          map.getSource("pieces").getClusterExpansionZoom(clusterId, (err, zoom) => {
            if (err) return;
            map.easeTo({ center: f.geometry.coordinates, zoom });
          });
        });
        map.on("click", "pins", (e) => {
          const f = e.features[0];
          new mapboxgl.Popup({ closeButton: false, maxWidth: "220px" })
            .setLngLat(f.geometry.coordinates)
            .setHTML(popupHtml(f.properties))
            .addTo(map);
        });
        for (const layer of ["clusters", "pins"]) {
          map.on("mouseenter", layer, () => (map.getCanvas().style.cursor = "pointer"));
          map.on("mouseleave", layer, () => (map.getCanvas().style.cursor = ""));
        }
      });
    }
    init();
  </script>
</Base>

<style>
  h1 { font-size: 2rem; margin: 0 0 0.5rem; letter-spacing: -0.02em; }
  .lede { max-width: 60ch; margin: 0 0 1.5rem; }
  .map {
    height: 70vh;
    min-height: 500px;
    border-radius: 8px;
    border: 1px solid #1f1f1f;
    overflow: hidden;
    background: #0a0a0a;
  }
</style>
