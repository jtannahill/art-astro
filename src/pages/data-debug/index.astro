---
/**
 * Debug surface for the data pipeline.
 * Lives at /next/_data/ — proves the DynamoDB scan made it
 * into Content Collections at build time.
 */
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

const weather = await getCollection("weather");
const palettes = await getCollection("palettes");

const runs = new Set(weather.map((w) => w.data.run_id).filter(Boolean));
const artists = new Set(weather.map((w) => w.data.artist).filter(Boolean));
const locations = new Set(palettes.map((p) => p.data.location_slug));

const recent = [...weather]
  .sort((a, b) => (b.data.run_id ?? "").localeCompare(a.data.run_id ?? ""))
  .slice(0, 6);

const buildTime = new Date().toISOString();
---

<Base title="Data debug — art.jt / next" description="Build-time data snapshot.">
  <h1>Data pipeline</h1>
  <p class="muted">
    DynamoDB <code>art-generator</code> scanned at build time, hydrated into
    Astro Content Collections, validated by Zod. Counts below are real.
  </p>

  <section class="card">
    <h2>Snapshot</h2>
    <dl>
      <dt>built</dt><dd class="mono">{buildTime}</dd>
      <dt>weather pieces</dt><dd class="mono">{weather.length}</dd>
      <dt>palettes</dt><dd class="mono">{palettes.length}</dd>
      <dt>runs</dt><dd class="mono">{runs.size}</dd>
      <dt>artists</dt><dd class="mono">{artists.size}</dd>
      <dt>palette locations</dt><dd class="mono">{locations.size}</dd>
    </dl>
  </section>

  <h2>Latest 6 weather pieces</h2>
  <table>
    <thead><tr>
      <th>run</th><th>artist</th><th>slug</th><th>temp</th><th>wind</th><th>pressure</th>
    </tr></thead>
    <tbody>
      {recent.map((w) => (
        <tr>
          <td class="mono">{w.data.run_id}</td>
          <td>{w.data.artist}</td>
          <td>{w.data.slug}</td>
          <td>{w.data.temp ?? "—"}°C</td>
          <td>{w.data.wind_speed ?? "—"} m/s</td>
          <td>{w.data.pressure ?? "—"} hPa</td>
        </tr>
      ))}
    </tbody>
  </table>
</Base>

<style>
  h1 { font-size: 2rem; margin: 0 0 0.5rem; }
  h2 { font-size: 1.1rem; margin: 2rem 0 1rem; }
  code {
    background: #1a1a2e;
    color: var(--color-accent);
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    font-family: var(--font-mono);
    font-size: 0.9em;
  }
  .card {
    border: 1px solid #2a2a2a;
    border-radius: 8px;
    padding: 1.5rem;
    margin: 1.5rem 0;
  }
  dl {
    display: grid;
    grid-template-columns: 11rem 1fr;
    gap: 0.4rem 1rem;
    margin: 0;
    font-size: 0.95rem;
  }
  dt { color: var(--color-muted); margin: 0; }
  dd { margin: 0; }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }
  th, td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid #1a1a1a;
    text-align: left;
  }
  th { color: var(--color-muted); font-weight: 500; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; }
  td { color: #ccc; }
</style>
