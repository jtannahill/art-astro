---
/**
 * Paginated weather archive.
 *
 * Production /weather/ ships ~1MB of HTML and 864 lazy <img> tags on a
 * single page. This route groups pieces by run (one run = ~10 pieces
 * generated together) and paginates by run, so each rendered page
 * carries at most ~80 images.
 *
 * Single-piece pages still live on production at /weather/{run_id}/{slug}/.
 */
import type { GetStaticPaths, Page } from "astro";
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Thumb from "../../components/Thumb.astro";

interface RunGroup {
  run_id: string;
  date: string;
  pieces: PieceMeta[];
}

interface PieceMeta {
  run_id: string;
  slug: string;
  artist: string;
  rationale: string;
  preview_url: string;
  page_url: string;
  temp?: number;
  wind_speed?: number;
  pressure?: number;
  score?: number;
  quality_score?: number;
}

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  // Pre-render in production CDN URLs so the staging archive does not
  // need its own image pipeline yet. Cutover swaps these to optimized
  // /-served variants once we add an image script.
  const PROD = "https://art.jamestannahill.com";
  const all = await getCollection("weather");
  const groups = new Map<string, typeof all>();
  for (const w of all) {
    const rid = w.data.run_id || w.data.date;
    if (!rid) continue;
    if (!groups.has(rid)) groups.set(rid, []);
    groups.get(rid)!.push(w);
  }
  const runs: RunGroup[] = [...groups.entries()]
    .map(([run_id, items]) => ({
      run_id,
      date: items[0].data.date || run_id.slice(0, 10),
      pieces: items
        .map((w) => ({
          run_id: w.data.run_id,
          slug: w.data.slug,
          artist: w.data.artist,
          rationale: w.data.rationale,
          preview_url: `${PROD}/weather/${w.data.run_id}/${w.data.slug}/preview-2048.png`,
          page_url: `${PROD}/weather/${w.data.run_id}/${w.data.slug}/`,
          temp: w.data.temp,
          wind_speed: w.data.wind_speed,
          pressure: w.data.pressure,
          score: w.data.score,
          quality_score: w.data.quality_score,
        }))
        .sort((a, b) => (b.quality_score ?? 0) - (a.quality_score ?? 0)),
    }))
    .sort((a, b) => b.run_id.localeCompare(a.run_id));

  return paginate(runs, { pageSize: 8 });
};

const { page } = Astro.props as { page: Page<RunGroup> };
const runs = page.data;

const totalRuns = page.total;
const totalPieces = runs.reduce((acc, r) => acc + r.pieces.length, 0);

// Distinct artists across this page, for the filter chip row.
const pageArtists = [...new Set(runs.flatMap((r) => r.pieces.map((p) => p.artist)))]
  .sort()
  .map((slug) => ({
    slug,
    name: slug.split("_").map((s) => s.charAt(0).toUpperCase() + s.slice(1)).join(" "),
  }));

function fmtArtist(slug: string) {
  return slug
    .split("_")
    .map((s) => s.charAt(0).toUpperCase() + s.slice(1))
    .join(" ");
}

function fmtRunDate(run_id: string) {
  // run_id is "YYYY-MM-DD-HHMMSS" or just "YYYY-MM-DD"
  const datePart = run_id.slice(0, 10);
  const tsPart = run_id.length > 10 ? run_id.slice(11) : "";
  if (!tsPart) return datePart;
  const hh = tsPart.slice(0, 2);
  const mm = tsPart.slice(2, 4);
  return `${datePart} ${hh}:${mm} UTC`;
}

const collectionLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `Weather Art Archive — page ${page.currentPage}`,
  url: `https://art.jamestannahill.com/archive/${page.currentPage > 1 ? page.currentPage + "/" : ""}`,
  description: `Browse ${totalRuns} weather-driven generations across the full archive.`,
  isPartOf: { "@type": "WebSite", name: "art.jt", url: "https://art.jamestannahill.com/" },
};
---

<Base
  title={`Archive page ${page.currentPage} — art.jt`}
  description={`Browse ${totalRuns} weather-driven generations across the full archive. Page ${page.currentPage} of ${page.lastPage}.`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(collectionLd)} />
  </Fragment>

  <h1>Archive</h1>
  <p class="muted">
    Every weather-driven generation, newest first. {totalRuns} runs · {totalPieces} pieces on this page · page {page.currentPage} of {page.lastPage}.
  </p>

  {/* Filter island. Chips toggle per-artist visibility on this page;
      the slider hides cards below a quality threshold. Hydration is
      a single inline script - no framework. State is per-page only;
      use /search/ for cross-page queries. */}
  <div class="filter-bar" data-archive-filter>
    <div class="chip-row">
      <button type="button" class="chip active" data-artist="*">All artists</button>
      {pageArtists.map((a) => (
        <button type="button" class="chip" data-artist={a.slug}>{a.name}</button>
      ))}
    </div>
    <label class="slider-row">
      <span>min quality</span>
      <input type="range" min="0" max="10" step="1" value="0" data-min-score />
      <span class="slider-val" data-slider-val>0</span>
      <span class="slider-shown" data-shown></span>
    </label>
  </div>

  {
    runs.map((run) => (
      <section class="run" data-run>
        <header class="run-head">
          <h2>{fmtRunDate(run.run_id)}</h2>
          <span class="run-count">{run.pieces.length} pieces</span>
        </header>
        <div class="grid">
          {run.pieces.map((p) => (
            <a
              class="card"
              href={p.page_url}
              rel="noopener"
              data-artist={p.artist}
              data-score={p.quality_score ?? 0}
            >
              <Thumb
                base={p.preview_url.replace(/\/preview-2048\.png$/, "")}
                alt={`${p.slug} (${fmtArtist(p.artist)})`}
                viewTransitionName={`art-${p.run_id.replace(/-/g, "")}-${p.slug.replace(/-/g, "")}`}
              />
              <div class="card-body">
                <h3>{p.slug.replace(/-/g, " ")}</h3>
                <p class="meta">{fmtArtist(p.artist)}</p>
                <p class="env">
                  {p.temp != null && <span>{p.temp.toFixed(1)}&deg;C</span>}
                  {p.wind_speed != null && <span>{p.wind_speed.toFixed(1)} m/s</span>}
                  {p.pressure != null && <span>{p.pressure.toFixed(0)} hPa</span>}
                </p>
              </div>
            </a>
          ))}
        </div>
      </section>
    ))
  }

  <script is:inline>
    (function () {
      const root = document.querySelector("[data-archive-filter]");
      if (!root) return;
      const chips = root.querySelectorAll(".chip");
      const slider = root.querySelector("[data-min-score]");
      const sliderVal = root.querySelector("[data-slider-val]");
      const shown = root.querySelector("[data-shown]");
      const cards = document.querySelectorAll(".card[data-artist]");
      const runs = document.querySelectorAll("[data-run]");
      let activeArtist = "*";

      function apply() {
        const min = Number(slider.value || 0);
        sliderVal.textContent = min;
        let visible = 0;
        cards.forEach((c) => {
          const a = c.dataset.artist;
          const s = Number(c.dataset.score || 0);
          const ok = (activeArtist === "*" || a === activeArtist) && s >= min;
          c.style.display = ok ? "" : "none";
          if (ok) visible++;
        });
        shown.textContent = ` · ${visible} shown`;
        // Hide an entire run if every card is filtered out
        runs.forEach((r) => {
          const anyVisible = !!r.querySelector('.card[data-artist]:not([style*="display: none"])');
          r.style.display = anyVisible ? "" : "none";
        });
      }

      chips.forEach((chip) => {
        chip.addEventListener("click", () => {
          activeArtist = chip.dataset.artist || "*";
          chips.forEach((c) => c.classList.toggle("active", c === chip));
          apply();
        });
      });
      slider.addEventListener("input", apply);
      apply();
    })();
  </script>

  <nav class="pager">
    {page.url.first && page.url.first !== page.url.current && (
      <a href={page.url.first}>« first</a>
    )}
    {page.url.prev && <a href={page.url.prev}>‹ prev</a>}
    <span class="muted">page {page.currentPage} / {page.lastPage}</span>
    {page.url.next && <a href={page.url.next}>next ›</a>}
    {page.url.last && page.url.last !== page.url.current && (
      <a href={page.url.last}>last »</a>
    )}
  </nav>
</Base>

<style>
  h1 { font-size: 2rem; margin: 0 0 0.5rem; letter-spacing: -0.02em; }
  h2 {
    font-size: 0.95rem;
    font-family: var(--font-mono);
    color: var(--color-fg);
    margin: 0;
    letter-spacing: 0;
    text-transform: none;
  }
  h3 {
    font-size: 0.95rem;
    margin: 0 0 0.25rem;
    color: #fff;
    text-transform: capitalize;
  }
  .run { margin: 2.5rem 0; }
  .run-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    border-bottom: 1px solid #222;
    padding-bottom: 0.4rem;
    margin-bottom: 1rem;
  }
  .run-count { color: var(--color-muted); font-size: 0.8rem; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }
  .card {
    display: block;
    background: #111;
    border: 1px solid #1f1f1f;
    border-radius: 8px;
    overflow: hidden;
    color: inherit;
    transition: transform 0.15s, border-color 0.15s;
  }
  .card:hover {
    transform: translateY(-2px);
    border-color: #333;
    text-decoration: none;
  }
  .thumb {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #0a0a0a;
  }
  .card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .card-body { padding: 0.6rem 0.75rem 0.75rem; }
  .meta {
    color: var(--color-accent);
    font-size: 0.78rem;
    margin: 0 0 0.4rem;
  }
  .env {
    color: var(--color-muted);
    font-size: 0.72rem;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.6rem;
  }

  .filter-bar {
    margin: 1.5rem 0 2rem;
    padding: 1rem 1.25rem;
    background: #111;
    border: 1px solid #1f1f1f;
    border-radius: 8px;
  }
  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.85rem;
  }
  .chip {
    padding: 0.3rem 0.7rem;
    background: #181818;
    color: #ccc;
    border: 1px solid #2a2a2a;
    border-radius: 999px;
    font-size: 0.78rem;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }
  .chip:hover { border-color: #444; }
  .chip.active {
    background: #1a1a2e;
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .slider-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.78rem;
    color: var(--color-muted);
  }
  .slider-row input[type="range"] {
    flex: 0 0 160px;
    accent-color: var(--color-accent);
  }
  .slider-val { color: #fff; font-family: var(--font-mono); min-width: 1.5em; }
  .slider-shown { color: var(--color-muted); font-size: 0.75rem; }

  .pager {
    margin: 3rem 0 1rem;
    padding: 1rem 0;
    border-top: 1px solid #222;
    display: flex;
    align-items: center;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
  .pager a {
    padding: 0.4rem 0.8rem;
    border: 1px solid #2a2a2a;
    border-radius: 6px;
    color: var(--color-link);
    text-decoration: none;
  }
  .pager a:hover { border-color: #444; background: #1a1a2e; }
</style>
