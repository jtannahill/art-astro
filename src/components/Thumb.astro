---
/**
 * Responsive artwork thumbnail. Renders a <picture> with WebP variants
 * at 480/960/1920 widths plus the original 2048 PNG as fallback.
 *
 * The WebP variants are generated by the art-image-resize Lambda
 * (S3-PUT-triggered on every preview-2048.png). When a piece is fresh
 * and the variants haven't landed yet, the PNG fallback handles it.
 *
 * Used by: archive cards, artist galleries, homepage today's-run grid,
 * comparison cells, single-piece hero (with eager loading).
 */
interface Props {
  /** Production absolute URL prefix for the piece, e.g.
   *  https://art.jamestannahill.com/weather/{run_id}/{slug} */
  base: string;
  alt: string;
  /** "lazy" for grids, "eager" for hero. */
  loading?: "lazy" | "eager";
  /** sizes attribute. Defaults to a reasonable card-grid breakpoints
   *  hint; pass "100vw" for hero. */
  sizes?: string;
  /** Optional view-transition-name to morph hero<->thumb on navigate. */
  viewTransitionName?: string;
  /** Aspect-ratio class to apply to the wrapper. */
  square?: boolean;
}

const {
  base,
  alt,
  loading = "lazy",
  sizes = "(max-width: 540px) 50vw, (max-width: 900px) 33vw, 240px",
  viewTransitionName,
  square = true,
} = Astro.props;

const png = `${base}/preview-2048.png`;
const webp480 = `${base}/preview-480.webp`;
const webp960 = `${base}/preview-960.webp`;
const webp1920 = `${base}/preview-1920.webp`;
const styleAttr = viewTransitionName
  ? `view-transition-name: ${viewTransitionName};`
  : undefined;
---

<picture class={square ? "thumb-pic square" : "thumb-pic"}>
  <source
    type="image/webp"
    srcset={`${webp480} 480w, ${webp960} 960w, ${webp1920} 1920w`}
    sizes={sizes}
  />
  <img
    src={png}
    alt={alt}
    loading={loading}
    decoding="async"
    width="1024"
    height="1024"
    style={styleAttr}
  />
</picture>

<style>
  .thumb-pic {
    display: block;
    width: 100%;
    background: #0a0a0a;
    overflow: hidden;
  }
  .thumb-pic.square { aspect-ratio: 1 / 1; }
  .thumb-pic img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
